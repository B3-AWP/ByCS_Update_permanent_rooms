# ByCS ViKo (Visavid) - Moderator-Beitritt (alle Dauerraeume)
# ===========================================================

# Login-Daten (oder aus Umgebungsvariable / bestehender .env uebernehmen).
# Eine gesetzte OS-Umgebungsvariable hat Vorrang vor diesen Dateiwerten.
# MEBIS_USERNAME=dein_username
# MEBIS_PASSWORD=dein_passwort

# Anzeigename auf der Beitrittsseite (max. 40 Zeichen)
VIKO_DISPLAY_NAME=Herr Nachname

# Standard: ALLE Dauerraeume nacheinander (je eigener Tab).
# Optional als Filter: nur Raeume, deren Name diesen Text enthaelt.
# VIKO_ROOM_NAME=AEuP

# Optional: direkter Raum-Link -> genau ein Raum, ueberspringt Liste + Dialog.
# VIKO_ROOM_URL=https://viko.bycs.de/v/0582-1624-3704

# --- Checkboxen der Beitrittsseite (gezielt, nicht blind alle) --------------
# "Name bei naechster Sitzung wiederverwenden"
VIKO_REUSE_NAME=True
# "Ton-Ausgabe bei Betreten des Raumes deaktivieren"
# Fuer aktive Moderation i.d.R. False (Ton an). True nur fuer stille Praesenz.
VIKO_MUTE_OUTPUT=False

# --- Browser ----------------------------------------------------------------
# True = ohne Fenster (Hintergrund-Bot), False = sichtbares Fenster.
MODE_HEADLESS=False
# Fake-Kamera/-Mikro. Bei mehreren parallelen Raeumen True lassen.
USE_FAKE_MEDIA=True
# Wartezeit (Sekunden) nach dem Beitritt, bis die Konferenz geladen ist,
# bevor der naechste Raum drankommt. Bei langsamer Verbindung erhoehen.
VIKO_JOIN_WAIT=5
# Alle Tabs offen halten bis Enter (True) statt sofort schliessen.
KEEP_OPEN=True
